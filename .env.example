DATABASE_URL=postgresql+psycopg://rag:rag@localhost:5432/ragdb
APP_ENV=dev
LOG_LEVEL=INFO

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM provider (used for answer generation and (optional) query rewrite)
LLM_PROVIDER=openai_compat
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=YOUR_KEY_HERE
LLM_MODEL=gpt-4o-mini

# Admin API security
ADMIN_API_KEY=CHANGE_ME_TO_A_LONG_RANDOM_VALUE
INGEST_ROOT=/data/uploads

# Retrieval tuning
TOP_K_VECTOR=50
TOP_K_LEXICAL=50
TOP_K_FINAL=12
MAX_CHUNKS_PER_DOC=3

# Optional: query rewrite (uses LLM)
QUERY_REWRITE_ENABLED=true

# Optional: reranking (cross-encoder). Requires `pip install -e '.[emb]'`
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Grounding gate
GROUNDING_MIN_CITATIONS=2

# Streaming
STREAM_CHUNK_CHARS=80
