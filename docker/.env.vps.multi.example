# Shared runtime defaults
APP_ENV=prod
LOG_LEVEL=INFO
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_PROVIDER=openai_compat
NEXT_GEN_RAG_ENABLED=false
RAG_CASES_PATH=config/rag_cases.yml
TOP_K_VECTOR=50
TOP_K_LEXICAL=50
TOP_K_FINAL=12
MAX_CHUNKS_PER_DOC=3
QUERY_REWRITE_ENABLED=true
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
GROUNDING_MIN_CITATIONS=2
STREAM_CHUNK_CHARS=80
SYNC_TOMBSTONE_ENABLED=false
SYNC_TOMBSTONE_GRACE_SECONDS=900
SYNC_ANTI_THRASH_BATCH_SIZE=200

# Shared Docker network between scaffold and RAG services
SCAFFOLD_SHARED_NETWORK=scaffold_shared

# ----------------------------
# Innovasjon RAG
# ----------------------------
RAG_INNOVASJON_API_PORT=8101
RAG_INNOVASJON_POSTGRES_USER=rag
RAG_INNOVASJON_POSTGRES_PASSWORD=change_me_innovasjon_db_password
RAG_INNOVASJON_POSTGRES_DB=rag_innovasjon
RAG_INNOVASJON_ADMIN_API_KEY=change_me_innovasjon_admin_key
RAG_INNOVASJON_UPLOADS_DIR=../uploads/innovasjon
RAG_INNOVASJON_LLM_BASE_URL=https://api.openai.com/v1
RAG_INNOVASJON_LLM_API_KEY=replace_with_real_key
RAG_INNOVASJON_LLM_MODEL=gpt-4o-mini
# Optional JSON map for per-request model_profile switching.
# Keep as single line.
RAG_INNOVASJON_LLM_PROFILES_JSON=
# Optional prompt overrides (absolute path or /app-relative path in container)
RAG_INNOVASJON_SYSTEM_PERSONA_PATH=/app/prompts/system_persona_bokskriving.md
RAG_INNOVASJON_ANSWER_TEMPLATE_PATH=/app/prompts/answer_template_bokskriving.md
# Optional explicit case allowlist for this instance
RAG_INNOVASJON_INSTANCE_CASE_IDS_JSON=["innovasjon","innovasjon_intervjuer","innovasjon_bokskriving"]
# Optional query router config
RAG_INNOVASJON_QUERY_ROUTER_ENABLED=false
RAG_INNOVASJON_QUERY_ROUTER_DOCS_SOURCE_TYPES_JSON=
RAG_INNOVASJON_QUERY_ROUTER_PROMPTS_SOURCE_TYPES_JSON=
RAG_INNOVASJON_QUERY_ROUTER_DOCS_KEYWORDS_JSON=
RAG_INNOVASJON_QUERY_ROUTER_PROMPTS_KEYWORDS_JSON=
RAG_INNOVASJON_RESEARCH_API_TOKENS_JSON=
RAG_INNOVASJON_RESEARCH_DOWNLOAD_SIGNING_KEY=
RAG_INNOVASJON_RESEARCH_DOWNLOAD_TTL_SECONDS=300
RAG_INNOVASJON_CELL_ACCESS_CONTROL_ENABLED=false
RAG_INNOVASJON_CELL_GATEWAY_SHARED_SECRET=
RAG_INNOVASJON_CELL_OWNER_USER_IDS_JSON=[]

# ----------------------------
# Dokumentasjon RAG (doc.haven.digipomps.org)
# Tekniske variabelnavn beholdes som RAG_DIMY_* for bakoverkompatibilitet.
# ----------------------------
RAG_DIMY_API_PORT=8102
RAG_DIMY_POSTGRES_USER=rag
RAG_DIMY_POSTGRES_PASSWORD=change_me_dimy_db_password
RAG_DIMY_POSTGRES_DB=rag_dimy
RAG_DIMY_ADMIN_API_KEY=change_me_dimy_admin_key
RAG_DIMY_UPLOADS_DIR=../uploads/dimy
RAG_DIMY_LLM_BASE_URL=https://api.openai.com/v1
RAG_DIMY_LLM_API_KEY=replace_with_real_key
RAG_DIMY_LLM_MODEL=gpt-4o-mini
# Optional JSON map for per-request model_profile switching.
# Keep as single line.
RAG_DIMY_LLM_PROFILES_JSON=
# Optional prompt overrides for documentation RAG
RAG_DIMY_SYSTEM_PERSONA_PATH=/app/prompts/system_persona_dimy.md
RAG_DIMY_ANSWER_TEMPLATE_PATH=/app/prompts/answer_template_dimy.md
# Optional explicit case allowlist for this instance
RAG_DIMY_INSTANCE_CASE_IDS_JSON=["dimy_docs","dimy_prompts"]
# Query router enabled by default for doc-RAG
RAG_DIMY_QUERY_ROUTER_ENABLED=true
RAG_DIMY_QUERY_ROUTER_DOCS_SOURCE_TYPES_JSON=["haven_docs","cellprotocol_docs"]
RAG_DIMY_QUERY_ROUTER_PROMPTS_SOURCE_TYPES_JSON=["dimy_prompts","prompt_docs"]
RAG_DIMY_QUERY_ROUTER_DOCS_KEYWORDS_JSON=["api","endpoint","kode","code","implementasjon","implementation","arkitektur","architecture","database","postgres","docker","deploy","sync","ingest","test","feil","error","bug"]
RAG_DIMY_QUERY_ROUTER_PROMPTS_KEYWORDS_JSON=["prompt","prompts","promptmal","system prompt","systeminstruksjon","instruksjon","instruction","template","mal","policy","agent"]
RAG_DIMY_RESEARCH_API_TOKENS_JSON=
RAG_DIMY_RESEARCH_DOWNLOAD_SIGNING_KEY=
RAG_DIMY_RESEARCH_DOWNLOAD_TTL_SECONDS=300
RAG_DIMY_CELL_ACCESS_CONTROL_ENABLED=false
RAG_DIMY_CELL_GATEWAY_SHARED_SECRET=
RAG_DIMY_CELL_OWNER_USER_IDS_JSON=[]
